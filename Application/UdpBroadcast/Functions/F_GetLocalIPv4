FUNCTION F_GetLocalIPv4 : STRING(16)
VAR
    stAdapter : SysSocket.SOCK_ADAPTER_INFORMATION;
    hAdapter  : UDINT;
    uxiSize   : __UXINT;
    udRes     : UDINT;
    iGuard    : UINT;

    sIp       : STRING(16);
    sHostName : STRING(64);
    stHost    : SysSocket.SOCK_HOSTENT;
    pIpAddr   : POINTER TO DWORD;
    stInAddr  : SysSocket.INADDR;
END_VAR
VAR CONSTANT
    INVALID_HANDLE_UDINT : UDINT := 16#FFFFFFFF;
END_VAR

F_GetLocalIPv4 := '';
sIp := '';

(* 1) Preferred path: enumerate adapters *)
uxiSize := SIZEOF(stAdapter);
hAdapter := SysSocket.SysSockGetFirstAdapterInfo(
    pAdapterInfo        := ADR(stAdapter),
    puxiAdapterInfoSize := ADR(uxiSize),
    pResult             := 0
);

iGuard := 0;
WHILE (hAdapter <> INVALID_HANDLE_UDINT) AND (iGuard < 32) DO
    iGuard := iGuard + 1;

    sIp := CONCAT(BYTE_TO_STRING(stAdapter.IpAddr.S_un_b.s_b1), '.');
    sIp := CONCAT(sIp, BYTE_TO_STRING(stAdapter.IpAddr.S_un_b.s_b2));
    sIp := CONCAT(sIp, '.');
    sIp := CONCAT(sIp, BYTE_TO_STRING(stAdapter.IpAddr.S_un_b.s_b3));
    sIp := CONCAT(sIp, '.');
    sIp := CONCAT(sIp, BYTE_TO_STRING(stAdapter.IpAddr.S_un_b.s_b4));

    IF (sIp <> '') AND (sIp <> '0.0.0.0') AND (sIp <> '127.0.0.1') THEN
        F_GetLocalIPv4 := sIp;
        RETURN;
    END_IF

    uxiSize := SIZEOF(stAdapter);
    hAdapter := SysSocket.SysSockGetNextAdapterInfo(
        hPrevAdapter       := hAdapter,
        pAdapterInfo       := ADR(stAdapter),
        puxiAdapterInfoSize:= ADR(uxiSize),
        pResult            := 0
    );
END_WHILE

(* 2) Fallback path: host name -> first host address *)
udRes := SysSocket.SysSockGetHostName(
    szHostName := sHostName,
    diNameLen  := SIZEOF(sHostName)
);
IF udRes <> UDINT#0 THEN
    RETURN;
END_IF

udRes := SysSocket.SysSockGetHostByName(
    szHostName := sHostName,
    pHost      := ADR(stHost)
);
IF udRes <> UDINT#0 THEN
    RETURN;
END_IF

pIpAddr := stHost.pAddrList[0];
IF pIpAddr = 0 THEN
    RETURN;
END_IF

stInAddr.ulAddr := pIpAddr^;
udRes := SysSocket.SysSockInetNtoa(
    pInAddr      := ADR(stInAddr),
    szIPADDR     := sIp,
    diIPAddrSize := SIZEOF(sIp)
);
IF udRes <> UDINT#0 THEN
    RETURN;
END_IF

IF (sIp = '') OR (sIp = '0.0.0.0') OR (sIp = '127.0.0.1') THEN
    RETURN;
END_IF

F_GetLocalIPv4 := sIp;
