{attribute 'pack_mode' := '1'}
(*
  Состояние и диагностика одного UDP-канала в формате Holding Registers (Modbus).
  Размер структуры: 32 регистра (WORD).
*)
TYPE ST_UdpBroadcastStateModbus :
STRUCT
    active                         : WORD;   (* 0 = FB неактивен, 1 = FB активен *)
    busy                           : WORD;   (* 0 = цикл передачи не выполняется, 1 = идет цикл передачи *)
    error                          : WORD;   (* 0 = ошибок нет, 1 = есть ошибка *)
    error_id                       : WORD;   (* Общий код последней ошибки FB (NBS.ERROR) *)

    sequence_id                    : WORD;   (* Номер цикла, младшее WORD *)
    packet_index                   : WORD;   (* Индекс текущего пакета *)
    packet_count                   : WORD;   (* Кол-во пакетов в цикле *)
    source_data_words              : WORD;   (* Длина входного массива, WORD *)
    effective_data_start_index     : WORD;   (* Фактический старт, WORD *)
    effective_data_end_index       : WORD;   (* Фактический конец, WORD *)
    effective_data_words           : WORD;   (* Фактическое кол-во слов, WORD *)
    send_count                     : WORD;   (* Счетчик отправленных пакетов, младшее WORD *)
    last_word_index                : WORD;   (* Индекс первого слова в последнем пакете, WORD *)
    last_word_count                : WORD;   (* Кол-во слов в последнем пакете *)
    cycle_done                     : WORD;   (* 0 = цикл не завершен, 1 = цикл передачи завершен *)

    diag_state                     : WORD;   (* Состояние автомата FB *)
    diag_error_source              : WORD;   (* Внутренний код источника ошибки FB: 0..10 *)
    diag_peer_enable               : WORD;   (* 0 = UDP_Peer запрещен, 1 = UDP_Peer разрешен *)
    diag_peer_active               : WORD;   (* 0 = UDP_Peer не активен, 1 = UDP_Peer активен *)
    diag_peer_error                : WORD;   (* 0 = ошибки UDP_Peer нет, 1 = есть ошибка UDP_Peer *)
    diag_peer_error_id             : WORD;   (* Код ошибки UDP_Peer (NBS.ERROR) *)
    diag_send_execute              : WORD;   (* 0 = вызова Send не было, 1 = выполнялся вызов Send *)
    diag_send_busy                 : WORD;   (* 0 = не занят, 1 = занят (поле зарезервировано) *)
    diag_send_error                : WORD;   (* 0 = ошибка Send отсутствует, 1 = есть ошибка Send *)
    diag_send_error_id             : WORD;   (* Код результата/ошибки udpPeer.Send (NBS.ERROR) *)
    diag_send_count                : WORD;   (* Отправлено байт, младшее WORD *)
    diag_send_length               : WORD;   (* Запрошено байт, младшее WORD *)
    diag_words_per_packet_limit    : WORD;   (* Лимит слов на пакет *)
    diag_effective_packet_bytes_limit : WORD; (* Лимит пакета, WORD *)
    diag_local_init_error          : WORD;   (* Результат SetInitialValue(LocalIp), NBS.ERROR *)
    diag_remote_init_error         : WORD;   (* Результат SetInitialValue(BroadcastIp), NBS.ERROR *)

    reserved                       : ARRAY[0..0] OF WORD; (* Резерв до 32 регистров *)
END_STRUCT
END_TYPE
