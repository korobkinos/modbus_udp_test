(*
  Состояние и диагностика одного канала UDP-рассылки.
  Каждый элемент массива state соответствует своему экземпляру FB.
*)
TYPE ST_UdpBroadcastState :
STRUCT
    active        : BOOL;         (* FB активен *)
    busy          : BOOL;         (* Выполняется цикл передачи *)
    error         : BOOL;         (* Общий флаг ошибки *)
    error_id      : NBS.ERROR;    (* Код последней ошибки *)

    sequence_id   : UDINT;        (* Номер текущего цикла передачи *)
    packet_index  : WORD;         (* Индекс текущего отправляемого пакета *)
    packet_count  : WORD;         (* Общее количество пакетов в цикле *)
    send_count    : UDINT;        (* Счетчик успешно отправленных пакетов *)

    source_data_words          : UDINT;  (* Длина входного массива Data в WORD *)
    effective_data_start_index : UDINT;  (* Фактический старт после ограничения *)
    effective_data_end_index   : UDINT;  (* Фактический конец после ограничения *)
    effective_data_words       : UDINT;  (* Фактическое количество WORD к отправке *)

    last_word_index : UDINT;     (* Индекс первого WORD в последнем отправленном пакете *)
    last_word_count : WORD;      (* Количество WORD в последнем отправленном пакете *)
    cycle_done      : BOOL;      (* Флаг завершения полного цикла *)

    diag_state                         : UINT;       (* Текущее состояние автомата *)
    diag_error_source                  : UINT;       (* Источник ошибки: 0-none,1-localIP,2-remoteIP,3-localIP=0.0.0.0,4-peer,5-array,6-range,7-words>limit,8-send,9-maxPacketCalc,10-sendLen>udpMax *)
    diag_peer_enable                   : BOOL;       (* Разрешение запуска UDP_Peer *)
    diag_peer_active                   : BOOL;       (* UDP_Peer активен *)
    diag_peer_error                    : BOOL;       (* Ошибка UDP_Peer *)
    diag_peer_error_id                 : NBS.ERROR;  (* Код ошибки UDP_Peer *)
    diag_send_execute                  : BOOL;       (* В текущем цикле выполнялся вызов Send *)
    diag_send_busy                     : BOOL;       (* Зарезервировано, сейчас FALSE *)
    diag_send_error                    : BOOL;       (* Ошибка Send *)
    diag_send_error_id                 : NBS.ERROR;  (* Код ошибки Send *)
    diag_send_count                    : UDINT;      (* Фактически отправлено байт *)
    diag_send_length                   : UDINT;      (* Запрошенная длина отправки, байт *)
    diag_words_per_packet_limit        : UINT;       (* Лимит WORD на пакет после расчетов *)
    diag_effective_packet_bytes_limit  : UDINT;      (* Примененный лимит UDP-пакета, байт *)
    diag_local_init_error              : NBS.ERROR;  (* Результат SetInitialValue(LocalIp) *)
    diag_remote_init_error             : NBS.ERROR;  (* Результат SetInitialValue(BroadcastIp) *)
END_STRUCT
END_TYPE
