(*
  Индивидуальные настройки одного канала UDP-рассылки.
  Каждый элемент массива cfg соответствует своему экземпляру FB.
*)
TYPE ST_UdpBroadcastConfig :
STRUCT
    enable                 : WORD  := 1;                    (* Режим автозапуска: 0=только ручной start_send, 1=периодический запуск по period_ms *)
    signature              : DWORD := 16#534B4D41;         (* Сигнатура заголовка, по умолчанию 'AMKS' *)
    local_port             : WORD  := 15001;               (* Локальный UDP-порт канала *)
    remote_port            : WORD  := 15000;               (* Удаленный UDP-порт канала *)
    max_packet_bytes_limit : WORD  := 1472;                (* Лимит размера UDP-пакета, байт. 0 = авто (до 65507) *)
    period_ms              : WORD  := 2000;                (* Период автозапуска цикла, миллисекунды *)
    start_send             : WORD  := 0;                    (* Ручной запуск цикла по фронту 0->1: 0/1 *)
    header_packet_type     : WORD  := 1;                   (* Тип пакета в заголовке *)
    header_version         : WORD  := 1;                   (* Версия протокола в заголовке *)
    payload_endianness     : WORD  := 0;                   (* Порядок байт в WORD payload: 0=little, 1=swap bytes *)
    inter_packet_delay_ms  : WORD  := 0;                   (* Пауза между пакетами внутри цикла, мс *)
    udp_data_start_index     : WORD  := 0;                 (* Начальный индекс данных в массиве Data *)
    udp_data_count_register  : WORD  := 35000;             (* Количество WORD для отправки, начиная с udp_data_start_index *)
END_STRUCT
END_TYPE

