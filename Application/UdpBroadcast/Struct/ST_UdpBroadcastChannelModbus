{attribute 'pack_mode' := '1'}
(*
  Полный Modbus-блок одного канала UDP:
  - cfg   : настройки канала (16 WORD)
  - state : состояние и диагностика (32 WORD)
  Итого: 48 WORD на канал.
*)
TYPE ST_UdpBroadcastChannelModbus :
STRUCT
    cfg   : ST_UdpBroadcastConfigModbus;
    state : ST_UdpBroadcastStateModbus;
END_STRUCT
END_TYPE